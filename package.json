{
  "name": "sgtwiki",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "editor"
  ],
  "scripts": {
    "dev": "bun run editor:dev & bun run ssg:dev & wait",
    "editor:dev": "bun cli/index.ts serve",
    "editor:build": "bun run --cwd editor build",
    "ssg:build": "bun cli/index.ts build",
    "ssg:serve": "bun cli/index.ts serve-ssg",
    "ssg:dev": "bun cli/index.ts dev",
    "fetch-deps": "bun cli/index.ts fetch-deps"
  }
}
